# ════════════════════════════════════════════════════════════════════
# crewroster-web - environment variables
# ════════════════════════════════════════════════════════════════════
# Conventions:
#   - All vars here are read by lib/env.ts. Do not access process.env
#     directly anywhere else (lint enforces).
#   - NEXT_PUBLIC_* prefix → inlined at build into client bundles
#     (browser-readable). Use only for non-secret values.
#   - Non-prefixed vars are server-only (Server Actions, RSC, Route
#     Handlers, instrumentation hooks).
#
# Companion docs at workspace root:
#   POLISH-RULES.md · POLISH-INITIATIVE.md · REQUIREMENTS.md
# ════════════════════════════════════════════════════════════════════

# ──── API endpoints ────────────────────────────────────────────────
# Backend API base URL - public client + server. Required.
# Dev: http://localhost:3000/api  ·  Prod: https://api.<domain>/api
NEXT_PUBLIC_BACKEND_API_URL=http://localhost:3000/api

# Server-side override - preferred for Server Actions / RSC.
# Falls back to NEXT_PUBLIC_BACKEND_API_URL when unset.
BACKEND_API_URL=http://localhost:3000/api

# Public app URL (used for absolute links + redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3001

# ──── PWA (installable web app) ────────────────────────────────────
# Master switch for the installable-app behaviour (service worker + install
# prompt). DEFAULT ON. Set to "false" to turn it off - the registrar then
# unregisters any installed worker and purges its caches. The worker only
# registers in production builds even when enabled (dev skips it).
NEXT_PUBLIC_PWA_ENABLED=true

# ──── Connect image CDN resizing (optional) ────────────────────────
# Read by lib/media/imageUrl.ts. When set, Connect image surfaces (feed grids,
# marketplace cards, avatars/logos) request right-sized variants via Cloudflare
# Image Resizing - /cdn-cgi/image/w=<w>,q=75,f=auto/<src> - instead of shipping
# the full 1600px upload into a small cell. EMPTY = OFF (full-size URLs served
# as-is; zero behaviour change).
#
# REQUIREMENT: Cloudflare Image Resizing only works when the public R2 bucket is
# served through a PROXIED custom domain (orange-cloud / "Proxied" in the DNS
# tab) on a zone with Image Resizing enabled (Speed > Optimization). It does NOT
# work on a raw `*.r2.dev` URL. Point this at that custom domain ORIGIN (no
# trailing path), and serve uploads from the same domain (set the backend R2
# public URL to it) so variants resolve. Example:
# NEXT_PUBLIC_IMAGE_TRANSFORM_BASE=https://cdn.manekhr.in
NEXT_PUBLIC_IMAGE_TRANSFORM_BASE=

# ──── Google OAuth (sign-in button) ────────────────────────────────
# Client ID from Google Cloud Console → OAuth 2.0 client (Web application).
# Origin must include http://localhost:3001 (dev) and prod app origin.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# ──── Sentry (Phase 0.9 - crash reporting) ─────────────────────────
# Create a new Next.js project at https://sentry.io. DSN is safe to expose.
NEXT_PUBLIC_SENTRY_DSN=
# Tag for environment in the Sentry UI (optional - defaults to NODE_ENV).
NEXT_PUBLIC_SENTRY_ENV=

# Build-time source-map upload (server-only - keep secret).
# Generate auth token at https://sentry.io/settings/account/api/auth-tokens/
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# ──── PostHog (Phase 0.10 - product analytics + session replay + flags) ─
# Sign up at https://posthog.com. Use the project public API key.
# Key is safe to expose - it identifies the project, not the secret.
NEXT_PUBLIC_POSTHOG_KEY=
# US cloud: https://us.i.posthog.com  ·  EU: https://eu.i.posthog.com  ·  self-host: your URL
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ──── Google Analytics 4 (Phase 0.10 - marketing/SEO attribution) ──
# GA4 measurement ID format: G-XXXXXXXXXX
# Create property at https://analytics.google.com → Admin → Data Streams.
NEXT_PUBLIC_GA4_MEASUREMENT_ID=

# ──── Google AdSense (Connect ad rails) ────────────────────────────
# Powers the Google-ads slot in the Connect ad rails (marketplace / company /
# storefront). EMPTY = Google ads OFF (the loader is not mounted; AdSlot renders
# nothing). To turn on, set the publisher id + a numeric slot id per rail slot
# (create one ad unit each at https://adsense.google.com → Ads → By ad unit),
# then rebuild. Personalization/consent (DPDP) is governed by the AdSense
# account / a CMP.
NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-XXXXXXXXXXXXXXXX
NEXT_PUBLIC_ADSENSE_SLOT_RIGHT_TOP=
NEXT_PUBLIC_ADSENSE_SLOT_RIGHT_MID=
NEXT_PUBLIC_ADSENSE_SLOT_LEFT_TOP=


# App Lock idle timeout (ms) before the Quick-PIN lock fires. Activity resets
# the timer. Default 5 min (300000). Keep in sync with the backend's
# APP_LOCK_IDLE_MS. Range 60000 (1 min) – 1800000 (30 min).
NEXT_PUBLIC_APP_LOCK_IDLE_MS=300000


# ════════════════════════════════════════════════════════════════════
# Additional variables (documented 2026-06-26 — deployment readiness)
# Read by lib/env.ts; all have safe defaults. Listed so prod config is complete.
# ════════════════════════════════════════════════════════════════════

# Sentry release tag for the web build (maps errors to a build). Usually set by
# CI to the git SHA. Falls back to SENTRY_RELEASE, then empty.
NEXT_PUBLIC_SENTRY_RELEASE=
SENTRY_RELEASE=
# SINGLE support/contact email shown EVERYWHERE (marketing contact + footer, in-app
# "contact support", cancellation, attendance device-setup help). Code default is
# support@manekhr.in. Set this to your one real inbox and it reflects across the app.
NEXT_PUBLIC_SUPPORT_EMAIL=manekhrapp@gmail.com
# NEXT_PUBLIC_SUPPORT_EMAIL=support@manekhr.in
# Single support WhatsApp/phone number (wa.me format: country code + digits, no
# +/spaces, e.g. 919876543210). Empty = the WhatsApp contact option is hidden.
NEXT_PUBLIC_SUPPORT_PHONE=
# DPDP grievance contact email shown on the deletion / grievance page.
# Falls back to NEXT_PUBLIC_SUPPORT_EMAIL when unset, so one mailbox can cover both.
NEXT_PUBLIC_GRIEVANCE_EMAIL=
# AdSense slot id for the marketplace-grid placement. Empty = no ad rendered.
NEXT_PUBLIC_ADSENSE_SLOT_MARKETPLACE_GRID=
# Connect rollout phase gate (controls which Connect surfaces are exposed).
NEXT_PUBLIC_CONNECT_PHASE=
# Enable real Razorpay payments in the UI. 'true' to turn on; default off
# (checkout stays gated/dormant until go-live).
NEXT_PUBLIC_PAYMENTS_ENABLED=false
# Dev-only: mock the auth OTP (skip real SMS). 'true' in local/dev ONLY —
# must be unset/false in production.
NEXT_PUBLIC_AUTH_OTP_MOCK=false
# SMS-OTP login on/off. Enabled by default; set to 'false' to fall back to the
# mock OTP flow (pairs with NEXT_PUBLIC_AUTH_OTP_MOCK).
NEXT_PUBLIC_SMS_OTP_ENABLED=true
# MSG91 OTP Widget (2026-07). MUST match the backend's AUTH_OTP_CHANNEL, or
# this FE will call widget SDK methods the backend isn't expecting (or vice
# versa) and every OTP send/verify will fail.
#   widget (default) - loads MSG91's client SDK; needs the two widget
#                       credentials below. No DLT sender-ID needed.
#   dlt               - no SDK loaded, FE submits the typed code directly
#                       (original behaviour, unchanged).
NEXT_PUBLIC_AUTH_OTP_CHANNEL=widget
# MSG91 Widget ID — from MSG91 dashboard → OTP Widget/SDK → Widgets.
NEXT_PUBLIC_MSG91_WIDGET_ID=
# MSG91 Widget token — from MSG91 dashboard → OTP Widget/SDK → Tokens →
# "+ Generate New Token" (NOT the account authkey; this one is designed to
# be public/browser-exposed). Required when NEXT_PUBLIC_AUTH_OTP_CHANNEL=widget.
NEXT_PUBLIC_MSG91_WIDGET_TOKEN_AUTH=