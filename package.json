{
  "name": "zari360-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "prepare": "husky",
    "dev": "next dev -p 4811",
    "check:i18n": "node scripts/check-i18n.js",
    "detect:hardcoded-i18n": "tsx scripts/detect-hardcoded-i18n.ts",
    "sync:upload-policies": "tsx scripts/sync-upload-policies.ts",
    "prebuild": "node scripts/check-i18n.js",
    "build": "next build",
    "postbuild": "node scripts/strip-sourcemaps.js",
    "start": "next start -p 4811",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,mjs,cjs,css,json,md}\" --ignore-path .prettierignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,mjs,cjs,css,json,md}\" --ignore-path .prettierignore",
    "typecheck": "tsc --noEmit",
    "test:lib": "node --experimental-test-isolation=none --test --import tsx lib/finance/amountInWords.spec.ts lib/finance/taxComputeClient.spec.ts lib/finance/precision.spec.ts lib/finance/draftStore.spec.ts lib/finance/payment-allocation.spec.ts lib/finance/voucherPrefs.spec.ts lib/rbac/path-matcher.spec.ts lib/rbac/permission-grid-payload.spec.ts lib/rbac/coherence.spec.ts lib/rbac/dep-resolver.spec.ts lib/rbac/grid-normalise.spec.ts components/dashboard/attendance/__tests__/memberSummary.spec.ts features/employee-hub/__tests__/memberFocusHref.spec.ts components/dashboard/team/salary/__tests__/useSalarySectionAccess.spec.ts",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:install": "playwright install --with-deps chromium"
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.0",
    "@next/third-parties": "^16.2.5",
    "@react-oauth/google": "^0.13.4",
    "@sentry/nextjs": "^10.51.0",
    "@tanstack/react-query": "^5.100.10",
    "@tanstack/react-virtual": "^3.13.24",
    "@types/papaparse": "^5.5.2",
    "antd": "^6.3.2",
    "axios": "^1.13.6",
    "dayjs": "^1.11.19",
    "firebase": "^11.10.0",
    "html-to-image": "^1.11.13",
    "idb": "^8.0.3",
    "jszip": "^3.10.1",
    "lucide-react": "^1.16.0",
    "next": "16.1.6",
    "next-intl": "^4.8.3",
    "papaparse": "^5.5.3",
    "posthog-js": "^1.372.9",
    "qrcode.react": "^4.2.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.73.1",
    "react-hotkeys-hook": "^5.3.2",
    "react-markdown": "^9.1.0",
    "recharts": "^3.8.0",
    "socket.io-client": "^4.8.3",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.2",
    "@zxing/library": "^0.22.0",
    "apexcharts": "^5.10.6",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "eslint-plugin-i18next": "^6.1.4",
    "fake-indexeddb": "^6.2.5",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "react-apexcharts": "^2.1.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.6"
  }
}
